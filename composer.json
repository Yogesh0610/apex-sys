{
    "name": "apexsys/server-migration",
    "description": "Automated server migration with SSH provisioning and email notifications for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Apex Systems",
            "email": "service@apexsys.in"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/mail": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Apexsys\\ServerMigration\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Apexsys\\ServerMigration\\ServerMigrationServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}